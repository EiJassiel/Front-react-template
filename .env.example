# Variables de entorno disponibles para el proyecto
# Copia este archivo como .env y modifica los valores según tus necesidades

# Nombre de la aplicación que aparece en la portada del ejemplo
VITE_APP_NAME=Front React Template

# Descripción breve de la aplicación
VITE_APP_DESCRIPTION=Plantilla base para proyectos frontend con React, Vite y JSX.

# URL de documentación (botón principal)
VITE_DOCS_URL=https://react.dev/

# URL del repositorio template en GitHub
VITE_USE_TEMPLATE_URL=https://github.com/your-username/your-repo

# URL para crear un Codespace
VITE_CODESPACE_URL=https://github.com/codespaces/new